// ─────────────────────────────────────────────────────────────────────────────
// M1 PAE Hub — Prisma Schema
// Back-end de Domínio: NestJS + Prisma + PostgreSQL
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Occurrence usa Strings pt-BR validadas na borda da API (src/domain/enums.ts),
// como role/accessLevel — decisão da revisão 2026-07-05 (plano §4.2).

enum AlertSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  EXPIRED
}

enum AlertType {
  SYSTEM
  OPERATIONAL
  SAFETY
  ENVIRONMENTAL
  SECURITY
  THRESHOLD
  MANUAL
}

enum WarRoomStatus {
  ACTIVE
  CLOSED
}

enum SafetyItemType {
  EPI
  TRAINING
  INSPECTION
  PROCEDURE
  INCIDENT
}

enum SafetyItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum AiInsightSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AiAgentType {
  MONITOR
  RCA
  SLA
  RECOMMENDATION
}

enum KnowledgeEntryType {
  RCA
  LESSON_LEARNED
  RECOMMENDATION
  PROCEDURE
  ANALYSIS
  MANUAL
}

// ─── Organization & Terminal ──────────────────────────────────────────────────

model Organization {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  logoUrl     String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  // Contador atômico do INC-#### sequencial por organização (Fase 2)
  occurrenceSeq Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  terminals      Terminal[]
  users          User[]
  entities       Entity[]
  occurrences    Occurrence[]
  risks          Risk[]
  emergencyPlans EmergencyPlan[]
  mapElements    MapElement[]
  paeDocuments   PAEDocument[]

  @@map("organizations")
}

// ─── Entidades externas & Acionamento (cadastro — Fase 4b) ────────────────────

model Entity {
  id             String   @id @default(uuid())
  organizationId String
  name           String   @db.VarChar(255)
  type           String   @db.VarChar(100) // Emergência | Ambiental | Autoridade Portuária ...
  contact        String?  @db.VarChar(100)
  status         String   @default("Ativo") @db.VarChar(20) // Ativo | Inativo
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id])
  permission          Permission?
  notificationRules   NotificationRule[]
  entityNotifications EntityNotification[]

  @@index([organizationId])
  @@map("entities")
}

// DER §6.3 — notificação DISPARADA numa ocorrência (operacional, Fase 3).
// Criada automaticamente ao abrir ocorrência: NotificationRule (tipo) × Permission (terminal).
model EntityNotification {
  id           String    @id @default(uuid())
  occurrenceId String
  entityId     String
  status       String    @default("Notificada") @db.VarChar(20) // Notificada | Confirmada | Pendente | Em Atendimento
  mandatory    Boolean   @default(false)
  confirmedAt  DateTime?
  respondingAt DateTime?
  dispatchedBy String?   @db.VarChar(255)
  createdAt    DateTime  @default(now())

  occurrence Occurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  entity     Entity     @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([occurrenceId])
  @@index([entityId])
  @@map("entity_notifications")
}

// ─── Fase 5a — Domínios de apoio à emergência (DER §6.1/§6.3) ────────────────
// Vocabulários pt-BR validados na borda (src/domain/enums.ts).

model Risk {
  id             String   @id @default(uuid())
  organizationId String
  terminalId     String
  type           String   @db.VarChar(100)
  description    String   @db.Text
  level          String   @default("médio") @db.VarChar(10) // baixo | médio | alto
  affectedArea   String?  @db.VarChar(255)
  date           DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  terminal     Terminal     @relation(fields: [terminalId], references: [id])

  @@index([organizationId])
  @@index([terminalId])
  @@map("risks")
}

model EmergencyPlan {
  id             String   @id @default(uuid())
  organizationId String
  terminalId     String
  name           String   @db.VarChar(255)
  description    String   @db.Text
  responsible    String?  @db.VarChar(255)
  // Checklist executável do template PAE: [{ text, done }]
  checklist      Json     @default("[]")
  status         String   @default("ativo") @db.VarChar(20) // ativo | inativo | em revisão
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  terminal     Terminal     @relation(fields: [terminalId], references: [id])

  @@index([organizationId])
  @@index([terminalId])
  @@map("emergency_plans")
}

model MapElement {
  id             String   @id @default(uuid())
  organizationId String
  terminalId     String
  name           String   @db.VarChar(255)
  layerType      String   @db.VarChar(30) // fire_equipment | hydrant | evacuation_route | risk_area | meeting_point
  latitude       Float
  longitude      Float
  description    String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  terminal     Terminal     @relation(fields: [terminalId], references: [id])

  @@index([organizationId])
  @@index([terminalId])
  @@map("map_elements")
}

// Biblioteca de documentos PAE (arquivo real na Fase 6 — hoje só metadados)
model PAEDocument {
  id             String   @id @default(uuid())
  organizationId String
  terminalId     String
  title          String   @db.VarChar(255)
  docType        String   @db.VarChar(50)
  description    String?  @db.Text
  fileName       String   @db.VarChar(255)
  uploadedBy     String?  @db.VarChar(255)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  terminal     Terminal     @relation(fields: [terminalId], references: [id])

  @@index([organizationId])
  @@index([terminalId])
  @@map("pae_documents")
}

// DER §6.1 — chat da ocorrência (Terminal ↔ Entidades). Decisão 2026-07-04:
// modelo próprio conforme o DER, sem reaproveitar WarRoomMessage.
model ChatMessage {
  id           String   @id @default(uuid())
  occurrenceId String
  userId       String
  message      String   @db.Text
  createdAt    DateTime @default(now())

  occurrence Occurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@index([occurrenceId])
  @@map("chat_messages")
}

model Permission {
  id          String   @id @default(uuid())
  entityId    String   @unique
  terminalIds String[] @default([]) // UUIDs de Terminal que a entidade atende
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("permissions")
}

model NotificationRule {
  id             String   @id @default(uuid())
  organizationId String
  occurrenceType String   @db.VarChar(100)
  entityId       String
  mandatory      Boolean  @default(false)
  createdAt      DateTime @default(now())

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([entityId])
  @@map("notification_rules")
}

model Terminal {
  id             String   @id @default(uuid())
  organizationId String
  name           String   @db.VarChar(255)
  code           String   @db.VarChar(50)
  description    String?  @db.Text
  location       String?  @db.VarChar(255)
  // Alinhamento ao DER §6.3 (Fase 4a)
  responsible    String?  @db.VarChar(255)
  contact        String?  @db.VarChar(100)
  latitude       Float?
  longitude      Float?
  status         String   @default("Ativo") @db.VarChar(20) // Ativo | Inativo | Revisão
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  users          User[]
  occurrences    Occurrence[]
  alerts         Alert[]
  risks          Risk[]
  emergencyPlans EmergencyPlan[]
  mapElements    MapElement[]
  paeDocuments   PAEDocument[]

  @@unique([organizationId, code])
  @@map("terminals")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id             String     @id @default(uuid())
  organizationId String
  terminalId     String?
  name                   String     @db.VarChar(255)
  email                  String     @unique @db.VarChar(255)
  passwordHash           String     @db.VarChar(255)
  role                   String     @default("terminal") @db.VarChar(20) // admin | terminal | entity
  accessLevel            String?    @db.VarChar(20)                       // estratégico | tático | operacional
  tacticalManagerId      String?                                         // Operacional → Tático
  allowedModules         String[]   @default([])
  allowedTerminals       String[]   @default([])
  allowedOccurrenceTypes String[]   @default([])
  status                 UserStatus @default(ACTIVE)
  avatarUrl              String?    @db.VarChar(500)
  phone                  String?    @db.VarChar(50)
  department             String?    @db.VarChar(100)
  lastLoginAt            DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id])
  terminal         Terminal?    @relation(fields: [terminalId], references: [id])
  tacticalManager  User?        @relation("TacticalTeam", fields: [tacticalManagerId], references: [id])
  managedOperators User[]       @relation("TacticalTeam")

  refreshTokens        RefreshToken[]
  reportedOccurrences  Occurrence[]         @relation("ReportedBy")
  timelineEvents       OccurrenceTimeline[]
  chatMessages         ChatMessage[]
  warRoomParticipants  WarRoomParticipant[]
  warRoomMessages      WarRoomMessage[]
  warRoomDecisions     WarRoomDecision[]
  acknowledgedAlerts   Alert[]              @relation("AcknowledgedBy")
  resolvedAlerts       Alert[]              @relation("ResolvedBy")
  safetyItems          SafetyItem[]
  auditLogs            AuditLog[]
  aiInsights           AgentInsight[]
  knowledgeEntries     KnowledgeEntry[]
  promptEvaluations    PromptEvaluation[]
  aiFeedback           AiFeedback[]

  @@index([organizationId])
  @@index([terminalId])
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─── Emergency Types ──────────────────────────────────────────────────────────

model EmergencyType {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  code        String   @unique @db.VarChar(50)
  description String?  @db.Text
  color       String?  @db.VarChar(20)
  icon        String?  @db.VarChar(50)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("emergency_types")
}

// ─── Occurrences ─────────────────────────────────────────────────────────────

// Alinhado ao DER §6.3 (Fase 2): vocabulário pt-BR, INC-#### por organização,
// responsible/team. Extras do Manus (title, emergencyType, SLA) removidos.
model Occurrence {
  id               String    @id @default(uuid())
  organizationId   String
  incNumber        String    @db.VarChar(20) // INC-#### sequencial por organização
  terminalId       String
  type             String    @db.VarChar(100) // tipo de ocorrência (livre, como no front)
  description      String    @db.Text
  status           String    @default("aberto") @db.VarChar(30) // aberto | em atendimento | emergência ativa | resolvido
  criticality      String    @default("média") @db.VarChar(20)  // baixa | média | alta | crítica
  severity         String?   @db.VarChar(20)                    // baixa | média | alta (obrigatória no despacho)
  responsible      String?   @db.VarChar(255)
  team             String?   @db.VarChar(255)
  location         String?   @db.VarChar(255)
  latitude         Float?
  longitude        Float?
  reportedByUserId String
  resolvedAt       DateTime?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  terminal     Terminal     @relation(fields: [terminalId], references: [id])
  reportedBy   User         @relation("ReportedBy", fields: [reportedByUserId], references: [id])

  timeline            OccurrenceTimeline[]
  evidences           Evidence[]
  alerts              Alert[]
  warRooms            WarRoom[]
  checklist           ChecklistItem[]
  aiInsights          AgentInsight[]
  entityNotifications EntityNotification[]
  chatMessages        ChatMessage[]

  @@unique([organizationId, incNumber])
  @@index([organizationId])
  @@index([terminalId])
  @@index([status])
  @@index([createdAt])
  @@map("occurrences")
}

// Timeline imutável (DER §6.3): eventos tipados em pt-BR (TIMELINE_EVENT_TYPE)
model OccurrenceTimeline {
  id           String   @id @default(uuid())
  occurrenceId String
  userId       String?
  eventType    String   @db.VarChar(50)
  description  String   @db.Text
  attachment   String?  @db.VarChar(255) // nome de arquivo (placeholder, como no front)
  metadata     Json?
  createdAt    DateTime @default(now())

  occurrence Occurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id])

  @@index([occurrenceId])
  @@map("occurrence_timeline")
}

// Fase 2: evidências só-metadados (upload real de arquivo fica na Fase 6 —
// por isso os campos de storage são opcionais).
model Evidence {
  id           String   @id @default(uuid())
  occurrenceId String
  uploadedById String?
  type         String   @default("documento") @db.VarChar(30) // foto | vídeo | documento | áudio | outro
  filename     String   @db.VarChar(255)
  originalName String?  @db.VarChar(255)
  mimeType     String?  @db.VarChar(100)
  sizeBytes    Int?
  storageKey   String?  @db.VarChar(500)
  storageUrl   String?  @db.VarChar(1000)
  description  String?  @db.Text
  createdAt    DateTime @default(now())

  occurrence Occurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  @@index([occurrenceId])
  @@map("evidences")
}

model ChecklistItem {
  id           String   @id @default(uuid())
  occurrenceId String
  title        String   @db.VarChar(255)
  isCompleted  Boolean  @default(false)
  completedAt  DateTime?
  completedBy  String?  @db.VarChar(255)
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  occurrence Occurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  @@index([occurrenceId])
  @@map("checklist_items")
}

// ─── Alerts ──────────────────────────────────────────────────────────────────

model Alert {
  id               String      @id @default(uuid())
  terminalId       String
  occurrenceId     String?
  title            String      @db.VarChar(255)
  message          String      @db.Text
  type             AlertType   @default(OPERATIONAL)
  severity         AlertSeverity @default(MEDIUM)
  status           AlertStatus @default(ACTIVE)
  source           String?     @db.VarChar(100)
  acknowledgedById String?
  acknowledgedAt   DateTime?
  resolvedById     String?
  resolvedAt       DateTime?
  expiresAt        DateTime?
  metadata         Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  terminal        Terminal    @relation(fields: [terminalId], references: [id])
  occurrence      Occurrence? @relation(fields: [occurrenceId], references: [id])
  acknowledgedBy  User?       @relation("AcknowledgedBy", fields: [acknowledgedById], references: [id])
  resolvedBy      User?       @relation("ResolvedBy", fields: [resolvedById], references: [id])

  @@index([terminalId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@map("alerts")
}

// ─── War Room ─────────────────────────────────────────────────────────────────

model WarRoom {
  id           String        @id @default(uuid())
  occurrenceId String
  title        String        @db.VarChar(255)
  status       WarRoomStatus @default(ACTIVE)
  openedAt     DateTime      @default(now())
  closedAt     DateTime?
  closedReason String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  occurrence   Occurrence           @relation(fields: [occurrenceId], references: [id])
  participants WarRoomParticipant[]
  messages     WarRoomMessage[]
  decisions    WarRoomDecision[]

  @@index([occurrenceId])
  @@map("war_rooms")
}

model WarRoomParticipant {
  id        String   @id @default(uuid())
  warRoomId String
  userId    String
  joinedAt  DateTime @default(now())
  leftAt    DateTime?

  warRoom WarRoom @relation(fields: [warRoomId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([warRoomId, userId])
  @@map("war_room_participants")
}

model WarRoomMessage {
  id        String   @id @default(uuid())
  warRoomId String
  userId    String
  content   String   @db.Text
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  warRoom WarRoom @relation(fields: [warRoomId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([warRoomId])
  @@map("war_room_messages")
}

model WarRoomDecision {
  id          String   @id @default(uuid())
  warRoomId   String
  userId      String
  description String   @db.Text
  createdAt   DateTime @default(now())

  warRoom WarRoom @relation(fields: [warRoomId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([warRoomId])
  @@map("war_room_decisions")
}

// ─── Safety ──────────────────────────────────────────────────────────────────

model SafetyItem {
  id           String           @id @default(uuid())
  terminalId   String?
  assignedToId String?
  type         SafetyItemType
  title        String           @db.VarChar(255)
  description  String?          @db.Text
  status       SafetyItemStatus @default(PENDING)
  dueDate      DateTime?
  completedAt  DateTime?
  metadata     Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  assignedTo User? @relation(fields: [assignedToId], references: [id])

  @@index([terminalId])
  @@index([status])
  @@map("safety_items")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String   @db.VarChar(100)
  resource   String   @db.VarChar(100)
  resourceId String?  @db.VarChar(100)
  details    Json?
  ipAddress  String?  @db.VarChar(50)
  userAgent  String?  @db.VarChar(500)
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── AI / Knowledge Platform ─────────────────────────────────────────────────

model AgentInsight {
  id           String            @id @default(uuid())
  userId       String?
  occurrenceId String?
  agentType    AiAgentType
  insightType  String            @db.VarChar(64)
  severity     AiInsightSeverity @default(INFO)
  title        String            @db.VarChar(255)
  content      String            @db.Text
  metadata     Json?
  readAt       DateTime?
  createdAt    DateTime          @default(now())

  user       User?       @relation(fields: [userId], references: [id])
  occurrence Occurrence? @relation(fields: [occurrenceId], references: [id])

  @@index([occurrenceId])
  @@index([agentType])
  @@map("agent_insights")
}

model KnowledgeEntry {
  id           String             @id @default(uuid())
  authorId     String?
  occurrenceId String?
  type         KnowledgeEntryType
  title        String             @db.VarChar(255)
  content      String             @db.Text
  tags         String[]
  isPublished  Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  author User? @relation(fields: [authorId], references: [id])

  @@index([type])
  @@map("knowledge_entries")
}

model PromptVersion {
  id           String   @id @default(uuid())
  promptKey    String   @db.VarChar(64)
  version      String   @db.VarChar(16)
  systemPrompt String   @db.Text
  userTemplate String   @db.Text
  variables    String[]
  notes        String?  @db.Text
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())

  evaluations PromptEvaluation[]

  @@unique([promptKey, version])
  @@index([promptKey])
  @@map("prompt_versions")
}

model PromptEvaluation {
  id              String   @id @default(uuid())
  promptVersionId String
  userId          String
  rating          Int
  feedback        String?  @db.Text
  createdAt       DateTime @default(now())

  promptVersion PromptVersion @relation(fields: [promptVersionId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@map("prompt_evaluations")
}

model AiFeedback {
  id           String   @id @default(uuid())
  userId       String
  occurrenceId String?
  analysisType String   @db.VarChar(64)
  rating       Int
  comment      String?  @db.Text
  inputHash    String?  @db.VarChar(64)
  outputHash   String?  @db.VarChar(64)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("ai_feedback")
}
