# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://pae_user:pae_password@localhost:5432/m1_pae_hub?schema=public"

# ─── Application ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_PREFIX=api
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:5173

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=your_very_long_and_secure_jwt_secret_here_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_very_long_and_secure_refresh_secret_here_minimum_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── AI / OpenAI ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2048

# ─── File Storage (S3 / Azure Blob) ──────────────────────────────────────────
STORAGE_PROVIDER=local   # local | s3 | azure
STORAGE_LOCAL_PATH=./uploads

# S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=m1-pae-evidences

# Azure Blob
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=evidences

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=debug   # debug | info | warn | error
